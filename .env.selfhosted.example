# Copy to .env.selfhosted for the self-hosted Convex staging profile.
# Keep your existing cloud-backed .env.local untouched for rollback.
#
# This single file is used by:
# - docker compose --env-file .env.selfhosted -f docker-compose.selfhosted.yml ...
# - npx convex ... --env-file .env.selfhosted
# - npm run dev:selfhosted / build:selfhosted / start:selfhosted
#
# Leave CONVEX_DEPLOYMENT unset here. Self-hosted CLI commands use
# CONVEX_SELF_HOSTED_URL + CONVEX_SELF_HOSTED_ADMIN_KEY instead.

# Local Dockerized self-hosted Convex URLs.
CONVEX_CLOUD_ORIGIN=http://127.0.0.1:3210
CONVEX_SITE_ORIGIN=http://127.0.0.1:3211

# Local app / browser runtime when pointing this repo at self-hosted staging.
NEXT_PUBLIC_CONVEX_URL=http://127.0.0.1:3210
NEXT_PUBLIC_CONVEX_SITE_URL=http://127.0.0.1:3211

# Self-hosted Convex CLI access. Generate the admin key after the stack starts:
# npm run selfhosted:admin-key
CONVEX_SELF_HOSTED_URL=http://127.0.0.1:3210
CONVEX_SELF_HOSTED_ADMIN_KEY=replace-with-generated-admin-key

# Backend runtime secrets.
# If you change INSTANCE_NAME, keep POSTGRES_DB aligned with the same value
# after replacing dashes with underscores.
INSTANCE_NAME=convex-self-hosted
INSTANCE_SECRET=replace-with-openssl-rand-hex-32

# Postgres settings. POSTGRES_URL is assembled in docker-compose.selfhosted.yml
# without a database name because Convex derives the database from INSTANCE_NAME.
POSTGRES_USER=convex
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_DB=convex_self_hosted
DO_NOT_REQUIRE_SSL=1

# Container image tags.
CONVEX_SELF_HOSTED_IMAGE_TAG=latest
RUST_LOG=info
DISABLE_METRICS_ENDPOINT=true

# These are pushed into the self-hosted Convex deployment via
# `npm run convex:selfhosted:env:sync`.
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-5-mini
OPENAI_REASONING_MODEL=gpt-5.4
