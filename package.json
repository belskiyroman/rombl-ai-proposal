{
  "name": "rombl-ai-proposal",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:selfhosted": "node --env-file=.env.selfhosted ./node_modules/next/dist/bin/next dev",
    "build": "next build",
    "build:selfhosted": "node --env-file=.env.selfhosted ./node_modules/next/dist/bin/next build",
    "extension:build": "node scripts/build-extension.mjs",
    "extension:watch": "node scripts/build-extension.mjs --watch",
    "start": "next start",
    "start:selfhosted": "node --env-file=.env.selfhosted ./node_modules/next/dist/bin/next start",
    "seed:candidates:selfhosted": "node --env-file=.env.selfhosted ./scripts/seed-candidates.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "selfhosted:up": "docker compose --env-file .env.selfhosted -f docker-compose.selfhosted.yml up -d",
    "selfhosted:down": "docker compose --env-file .env.selfhosted -f docker-compose.selfhosted.yml down",
    "selfhosted:logs": "docker compose --env-file .env.selfhosted -f docker-compose.selfhosted.yml logs -f",
    "selfhosted:admin-key": "docker compose --env-file .env.selfhosted -f docker-compose.selfhosted.yml exec backend ./generate_admin_key.sh",
    "convex:selfhosted:dev": "npx convex dev --env-file .env.selfhosted",
    "convex:selfhosted:push": "npx convex dev --env-file .env.selfhosted --once",
    "convex:selfhosted:env:list": "npx convex env list --env-file .env.selfhosted",
    "convex:selfhosted:env:sync": "node --env-file=.env.selfhosted ./scripts/sync-selfhosted-convex-env.mjs",
    "convex:selfhosted:import": "npx convex import --env-file .env.selfhosted"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@langchain/langgraph": "^1.2.0",
    "@langchain/openai": "^1.2.11",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-toast": "^1.2.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.23.0",
    "lucide-react": "^0.475.0",
    "next": "^15.2.0",
    "openai": "^4.87.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.71.2",
    "tailwind-merge": "^3.0.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.24",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "autoprefixer": "^10.4.20",
    "esbuild": "^0.25.1",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
